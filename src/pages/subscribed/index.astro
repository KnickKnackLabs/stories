---
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="Check your inbox · Knick Knack Labs Stories"
  description="Thanks for subscribing to Knick Knack Labs Stories."
>
  <main>
    <section class="messagePanel">
      <p class="eyebrow">Subscribed</p>
      <h1>Thanks — check your inbox.</h1>
      <p>
        Buttondown may ask you to confirm your email address before you receive Knick Knack
        Labs Stories. If a confirmation email arrives, click the link there to finish signing up.
      </p>
      <p>
        No email? Give it a minute, then check spam or promotions. If you were already on the
        list, Buttondown may not send another confirmation.
      </p>
      <a class="buttonLink" href="/">Back to stories</a>
    </section>
  </main>
</Layout>
