---
const { compact = false } = Astro.props;
const buttondownUsername = 'knickknacklabs';
const subscribeAction = `https://buttondown.com/api/emails/embed-subscribe/${buttondownUsername}`;
---

<section class:list={["subscribe", compact && "subscribeCompact"]}>
  <div>
    <p class="eyebrow">Mailing list</p>
    <h2>Get the next story</h2>
    <p>
      Occasional KKL stories about prototypes, agents, tools, and weird little interfaces.
    </p>
  </div>

  <form class="subscribeForm" action={subscribeAction} method="post">
    <label>
      <span>Email</span>
      <input type="email" name="email" placeholder="you@example.com" autocomplete="email" required />
    </label>
    <input type="hidden" name="embed" value="1" />
    <input type="hidden" name="tag" value="stories-site" />
    <button type="submit">Subscribe</button>
  </form>

  <p class="finePrint">Uses Buttondown. You’ll get a confirmation email before anything is sent.</p>
</section>
